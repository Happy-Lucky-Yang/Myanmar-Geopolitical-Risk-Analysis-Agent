# ========================================
# 缅甸地缘风险智能分析原型系统 - 环境变量模板
# 复制本文件为 .env 并填入实际值
# ========================================

# ---------- 大模型 API ----------
# 实验室部署的大模型地址（兼容 OpenAI Chat Completions 格式）
LLM_API_URL=http://your-lab-server.com/v1/chat/completions
LLM_API_KEY=your-secret-key
LLM_MODEL_NAME=geopolitical-gpt

# ---------- Neo4j 图数据库（可选，不装也能跑） ----------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ---------- Flask 服务 ----------
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true

# ---------- 数据存储 ----------
DATA_RAW_DIR=./data/raw
DATA_PROCESSED_DIR=./data/processed
DATA_EXTERNAL_DIR=./data/external
